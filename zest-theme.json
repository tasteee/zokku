		"interface": { "foreground": "#C8B0E0" },
		"interface.declaration": { "foreground": "#C8B0E0" },
		"type": { "foreground": "#C8B0E0" },
		"type.declaration": { "foreground": "#C8B0E0" },
		"enum": { "foreground": "#C8B0E0" },
