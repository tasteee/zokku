	"semanticTokenColors": {
		"variable": { "foreground": "#93E49E" },
		"variable.readonly": { "foreground": "#93E49E" },
		"variable.defaultLibrary": { "foreground": "#93E49E" },
		"parameter": { "foreground": "#0F973C", "fontStyle": "italic" },
		"function": { "foreground": "#4FD168", "fontStyle": "bold" },
		"function.declaration": { "foreground": "#B0EDB8" },
